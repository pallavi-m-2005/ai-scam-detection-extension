{
  "manifest_version": 3,
  "name": "AI Scam Detector",
  "version": "1.0",
  "description": "Detects phishing and scam websites using AI",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "history"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
